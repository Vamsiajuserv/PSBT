# ── PSBT-Portal backend environment (template) ───────────────────────────────
# Copy to .env and fill in real values. Do NOT commit the real .env.
PGHOST=your-server.postgres.database.azure.com
PGUSER=your_db_user
PGPORT=5432
PGDATABASE=psbt_db
PGPASSWORD=your_password
PGSSLMODE=require

JWT_SECRET=change-me-generate-with-secrets.token_hex(32)
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

APP_NAME=PSBT-Portal API
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Payments — blank = sandbox provider (auto-success). Fill for live Razorpay.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Translation — blank = verified offline glossary. Add Azure AI Translator key for dynamic.
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
